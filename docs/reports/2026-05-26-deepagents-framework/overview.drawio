          <mxGeometry x="510" y="340" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="B-4" value="子任务完成&lt;br&gt;输出「结论摘要 / 结构化产出」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=12;fontStyle=1;" vertex="1" parent="1">

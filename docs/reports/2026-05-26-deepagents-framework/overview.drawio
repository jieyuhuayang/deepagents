        <mxCell id="A-header" value="子流程 A — 人工审批" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#7D3C98;strokeColor=#4A235A;fontColor=#FFFFFF;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="A-1" value="触发：大模型欲调用敏感工具&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#555;&quot;&gt;（例：写文件 / 执行命令 / 关键子任务）&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAEF;strokeColor=#7D3C98;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="A-2" value="任务暂停&lt;br&gt;向用户呈现「待审批操作 + 参数」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAEF;strokeColor=#7D3C98;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="245" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="A-3" value="用户决策" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7D3C98;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="335" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="A-4a" value="✅ 通过原参数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="A-4b" value="✏️ 改写参数后通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCF3CF;strokeColor=#B7950B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="450" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="A-4c" value="❌ 拒绝并附理由" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="450" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="A-5a" value="按原参数执行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2F8;strokeColor=#2874A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="A-5b" value="按新参数执行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2F8;strokeColor=#2874A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="540" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="A-5c" value="拒绝信息回传大模型&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;由模型自行调整策略&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="540" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="A-6" value="回到主循环「大模型思考」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCF3CF;strokeColor=#B7950B;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="360" height="50" as="geometry" />
        </mxCell>
        <mxCell id="A-note" value="价值：把人放在关键决策点上，既不让模型自动越权，又不让人盯所有步骤" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#7D3C98;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="420" height="30" as="geometry" />
        </mxCell>

        <mxCell id="B-2" value="启动专项助手&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#555;&quot;&gt;独立上下文 / 自有工具集 / 自有审批规则&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=12;fontStyle=1;" vertex="1" parent="1">

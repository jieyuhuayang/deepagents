          <mxGeometry x="510" y="620" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="B-note" value="价值：把复杂问题切片成「专项黑箱」，主任务上下文不被噪声淹没" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#C0392B;fontStyle=2;" vertex="1" parent="1">

          <mxGeometry x="490" y="90" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="B-1" value="主任务发起子任务&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#555;&quot;&gt;指定：子任务类型 + 任务描述&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="510" y="150" width="380" height="70" as="geometry" />

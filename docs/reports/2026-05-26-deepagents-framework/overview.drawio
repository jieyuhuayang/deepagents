<mxfile host="app.diagrams.net" agent="claude" pages="3">
  <diagram id="page-1-capabilities" name="① 能力全景">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1-title" value="任务模式智能体框架 — 能力全景" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1F3864;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="600" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p1-sub" value="一个让大模型自主完成多步骤复杂任务的框架，把「思考、调用工具、协作、记忆、审批、持久化」组合成一个可控的工作模式" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="120" y="68" width="960" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p1-c1" value="&lt;b style=&quot;font-size:15px;color:#1A5276;&quot;&gt;🧠 大模型驱动&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 思考—执行循环：边想边动手&lt;br&gt;• 多步迭代直至任务完成&lt;br&gt;• 可输出自然语言或结构化结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="340" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p1-c2" value="&lt;b style=&quot;font-size:15px;color:#7D6608;&quot;&gt;🛠️ 工具体系&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 一组「内置工具」开箱即用&lt;br&gt;• 可挂载业务工具，如知识库检索&lt;br&gt;• 大模型根据工具描述自主选用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCF3CF;strokeColor=#B7950B;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="120" width="340" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p1-c3" value="&lt;b style=&quot;font-size:15px;color:#7B241C;&quot;&gt;👥 子任务助手&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 把复杂问题拆给「专项助手」&lt;br&gt;• 各自独立的上下文与工具集&lt;br&gt;• 只回传结论，主任务不被打扰" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="120" width="340" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p1-c4" value="&lt;b style=&quot;font-size:15px;color:#196F3D;&quot;&gt;📋 计划与记忆&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 计划清单：边做边列待办&lt;br&gt;• 技能包：随用随取的方法手册&lt;br&gt;• 记忆库：跨任务沉淀的长期知识&lt;br&gt;• 工作区文件：临时草稿与产物" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="340" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p1-c5" value="&lt;b style=&quot;font-size:15px;color:#4A235A;&quot;&gt;✋ 人工审批&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 敏感操作自动暂停等待审批&lt;br&gt;• 三种处置：通过 / 改写参数 / 拒绝&lt;br&gt;• 把人放在关键决策点上" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAEF;strokeColor=#7D3C98;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="350" width="340" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p1-c6" value="&lt;b style=&quot;font-size:15px;color:#6E2C00;&quot;&gt;💾 状态与持久化&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 每一步状态自动落盘&lt;br&gt;• 任务被打断后可原地继续&lt;br&gt;• 长期记忆跨会话共享" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAE5D3;strokeColor=#BA4A00;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="350" width="340" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p1-flow" value="&lt;b style=&quot;font-size:14px;color:#1F3864;&quot;&gt;典型场景：知识库检索任务&lt;/b&gt;&lt;br&gt;&lt;br&gt;用户提问 ➜ 框架规划步骤 ➜ 调用「知识库检索」工具 ➜ 阅读结果并继续思考 ➜ 必要时启动子任务深挖 ➜ 关键写操作请用户审批 ➜ 返回结构化结论" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFCFC;strokeColor=#1F3864;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacingLeft=18;spacingTop=14;spacingRight=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="1080" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1-legend" value="阅读顺序：① 能力全景  →  ② 主执行流程  →  ③ 关键子流程（人工审批 / 子任务 / 持久化恢复）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#888888;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="730" width="960" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

# 必填:阿里云百炼控制台 https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 联网搜索:provider 切换走 SEARCH_PROVIDER,默认 duckduckgo(无需 API key,适合 demo,高频会限流)
# 可选 tavily(https://app.tavily.com) / cloudsway(https://console.cloudsway.ai)
# SEARCH_PROVIDER=duckduckgo
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLOUDSWAY_ACCESS_KEY=
# CLOUDSWAY_ENDPOINT=

# 可选:覆盖默认模型(默认 deepseek-v4-pro)
# DEEPAGENTS_MODEL=deepseek-v4-pro
# DEEPAGENTS_MODEL=qwen-max-latest

# BiSheng 知识库检索(无需 API key,网络层鉴权)
# BISHENG_KB_IDS 用逗号分隔支持多 KB,例如 "3404,3405"
BISHENG_BASE_URL=http://192.168.106.120:3002
BISHENG_KB_IDS=3404

# 可选:开启 LangSmith trace(不填也能跑)
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=deep-research

# ─── lab host 部署(langgraph up,Postgres 持久化)可选,本地 langgraph dev 用不到 ───
# 详见 docs/features/v0.5.0/001-langgraph-up-deployment/spec.md
# LANGGRAPH_PORT=8123      # langgraph-api 对外端口(默认 8123,与 host 已有服务冲突时改)
# POSTGRES_PORT=5433       # 自带 Postgres 对外端口(避免与 host 已有 5432 冲突)
# REDIS_PORT=6380          # 自带 Redis 对外端口
